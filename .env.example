# ─────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5) – self-hosted GitHub OAuth.
# ─────────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → New OAuth App
# 2. Homepage URL:        http://localhost:3000 (or your prod URL)
# 3. Authorization URL:   http://localhost:3000/api/auth/callback/github
# 4. Copy "Client ID"     → GITHUB_CLIENT_ID
# 5. Generate a secret    → GITHUB_CLIENT_SECRET
# 6. Generate an AUTH_SECRET: `openssl rand -base64 32`
#
# Optional: restrict /admin to a single GitHub username.
# Get this by visiting https://api.github.com/users/<your-username>.
ADMIN_GITHUB_LOGIN=nexuscreativ

GITHUB_CLIENT_ID=Ov23liMTyhHUCnPABDFT
GITHUB_CLIENT_SECRET=2860a5fe1a5da781a9583081302bf00a7848886d
AUTH_SECRET=5nMMEbSvit9iaP20L5gZ0APTRYK7IY1skpj/l4Jqkcw=

# ─────────────────────────────────────────────────────────────
# Production commits via the GitHub API.
# ─────────────────────────────────────────────────────────────
# In dev, /admin edits write directly to content/site/site.json
# and file uploads write to public/uploads/. No env vars needed.
#
# In production (Vercel), the filesystem is read-only, so we
# commit edits back to the GitHub repo, which triggers Vercel
# to auto-rebuild. Set these four vars on Vercel:
#
#   GITHUB_TOKEN         a fine-grained PAT (Contents: Read+Write
#                        on this single repo). Keep it secret.
#   GITHUB_REPO_OWNER    e.g. "your-username"
#   GITHUB_REPO_NAME     e.g. "myprofiler"
#   GITHUB_REPO_BRANCH   the branch Vercel builds from (default: main)
#
# Without these in production, /admin renders the form but saves
# will fail with a clear error.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=main

# ─────────────────────────────────────────────────────────────
# Public site URL – used for absolute og:image / canonical links.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
